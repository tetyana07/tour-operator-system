<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<ScrollPane styleClass="content-scroll" fitToWidth="true" xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.touroperator.ui.PaymentsController">
  <VBox styleClass="content-area" spacing="22">

    <HBox alignment="CENTER_LEFT">
      <VBox HBox.hgrow="ALWAYS" spacing="3">
        <Label text="Оплати" styleClass="page-title"/>
        <Label text="Транзакції, баланс та фінансова звітність" styleClass="page-sub"/>
      </VBox>
      <Button text="+ Прийняти оплату" styleClass="add-btn" onAction="#onAddPayment"/>
    </HBox>

    <!-- STATS — реальні дані -->
    <HBox spacing="14">
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="ВИРУЧКА (МІСЯЦЬ)" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="💰" styleClass="stat-icon-label"/>
        </HBox>
        <Label fx:id="statRevenue" text="..." styleClass="stat-value"/>
        <Label fx:id="statRevenueChange" text="" styleClass="stat-change"/>
      </VBox>
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="ОЧІКУЄТЬСЯ" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="⏳" styleClass="stat-icon-label"/>
        </HBox>
        <Label fx:id="statPending" text="..." styleClass="stat-value-green"/>
        <Label fx:id="statPendingCount" text="" styleClass="stat-change-muted"/>
      </VBox>
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="ПОВЕРНЕННЯ" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="🔄" styleClass="stat-icon-label"/>
        </HBox>
        <Label fx:id="statRefunds" text="..." styleClass="stat-value-red"/>
        <Label fx:id="statRefundsCount" text="" styleClass="stat-change-down"/>
      </VBox>
    </HBox>

    <!-- TABLE -->
    <VBox styleClass="table-card" spacing="0" VBox.vgrow="ALWAYS">
      <HBox styleClass="table-toolbar" alignment="CENTER_LEFT" spacing="10">
        <Label text="Транзакції" styleClass="table-title-lbl" HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="monthFilter" styleClass="filter-combo"
          promptText="Всі міс..." prefWidth="140" onAction="#onFilter"/>
        <ComboBox fx:id="typeFilter" styleClass="filter-combo"
          promptText="Всі типи" prefWidth="130" onAction="#onFilter"/>
      </HBox>

      <TableView fx:id="paymentsTable" VBox.vgrow="ALWAYS" styleClass="data-table"
        style="-fx-border-color: transparent; -fx-background-color: transparent;">
        <columns>
          <TableColumn fx:id="colId"        text="#"           prefWidth="115"/>
          <TableColumn fx:id="colClient"    text="КЛІЄНТ"      prefWidth="170"/>
          <TableColumn fx:id="colBookingId" text="БРОНЮВАННЯ"  prefWidth="115"/>
          <TableColumn fx:id="colMethod"    text="МЕТОД"       prefWidth="130"/>
          <TableColumn fx:id="colDate"      text="ДАТА"        prefWidth="115"/>
          <TableColumn fx:id="colAmount"    text="СУМА"        prefWidth="130"/>
          <TableColumn fx:id="colStatus"    text="СТАТУС"      prefWidth="120"/>
          <TableColumn fx:id="colActions"   text="ДІЇ"         prefWidth="60"/>
        </columns>
      </TableView>
    </VBox>

  </VBox>
</ScrollPane>
