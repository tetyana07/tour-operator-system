<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<ScrollPane styleClass="content-scroll" fitToWidth="true"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.touroperator.ui.DashboardController">
  <VBox styleClass="content-area" spacing="22">

    <!-- PAGE HEADER -->
    <HBox alignment="CENTER_LEFT">
      <VBox HBox.hgrow="ALWAYS" spacing="3">
        <Label text="Привіт, Тетяно 👋" styleClass="page-title"/>
        <Label text="Сьогодні 6 травня 2025 — 3 нових бронювання очікують підтвердження"
          styleClass="page-sub"/>
      </VBox>
      <Button text="+ Новий тур" styleClass="add-btn"/>
    </HBox>

    <!-- STATS 4-col -->
    <HBox spacing="14">
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="ВИРУЧКА (МІСЯЦЬ)" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="💰" styleClass="stat-icon-label"/>
        </HBox>
        <Label text="₴847k" styleClass="stat-value"/>
        <Label text="↑ +14% vs квітень" styleClass="stat-change"/>
      </VBox>
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="БРОНЮВАНЬ" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="📋" styleClass="stat-icon-label"/>
        </HBox>
        <Label text="47" styleClass="stat-value"/>
        <Label text="↑ +8 цього тижня" styleClass="stat-change"/>
      </VBox>
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="АКТИВНИХ ТУРІВ" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="✈️" styleClass="stat-icon-label"/>
        </HBox>
        <Label text="12" styleClass="stat-value"/>
        <Label text="↑ 3 нових" styleClass="stat-change"/>
      </VBox>
      <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="5">
        <HBox alignment="CENTER_LEFT">
          <Label text="НАПОВНЕНІСТЬ" styleClass="stat-label" HBox.hgrow="ALWAYS"/>
          <Label text="🎫" styleClass="stat-icon-label"/>
        </HBox>
        <Label text="78%" styleClass="stat-value"/>
        <Label text="↓ -4% квота" styleClass="stat-change-down"/>
      </VBox>
    </HBox>

    <!-- ACTIVE TOURS -->
    <VBox spacing="12">
      <HBox alignment="CENTER_LEFT">
        <Label text="Активні тури" styleClass="section-title" HBox.hgrow="ALWAYS"/>
        <Button text="Переглянути всі →" styleClass="see-all-btn"/>
      </HBox>
      <GridPane fx:id="toursGrid" hgap="14" vgap="14">
        <columnConstraints>
          <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33"/>
          <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33"/>
          <ColumnConstraints hgrow="ALWAYS" percentWidth="33.33"/>
        </columnConstraints>
      </GridPane>
    </VBox>

    <!-- BOTTOM ROW: chart + recent bookings -->
    <HBox spacing="16" alignment="TOP_LEFT">

      <!-- Chart -->
      <VBox HBox.hgrow="ALWAYS" spacing="10">
        <HBox alignment="CENTER_LEFT">
          <Label text="Бронювань по місяцях" styleClass="section-title" HBox.hgrow="ALWAYS"/>
          <Label text="2025" style="-fx-font-size:11px;-fx-text-fill:#8a9a85;"/>
        </HBox>
        <VBox styleClass="chart-panel">
          <HBox fx:id="chartBars" alignment="BOTTOM_LEFT" spacing="6" prefHeight="80"/>
        </VBox>
      </VBox>

      <!-- Recent bookings -->
      <VBox prefWidth="320" spacing="10">
        <HBox alignment="CENTER_LEFT">
          <Label text="Останні бронювання" styleClass="section-title" HBox.hgrow="ALWAYS"/>
          <Button text="Всі →" styleClass="see-all-btn"/>
        </HBox>
        <VBox styleClass="table-card" spacing="0">
          <!-- Row 1 -->
          <HBox styleClass="table-row" spacing="10">
            <Label text="ІМ" styleClass="c-ava ca-a"/>
            <VBox HBox.hgrow="ALWAYS" spacing="1">
              <Label text="Іваненко Марія" styleClass="td-normal"/>
              <Label text="Туреччина · 14 черв." styleClass="td-muted"/>
            </VBox>
            <Label text="Підтверджено" styleClass="pill-confirmed"/>
          </HBox>
          <!-- Row 2 -->
          <HBox styleClass="table-row" spacing="10">
            <Label text="ПО" styleClass="c-ava ca-b"/>
            <VBox HBox.hgrow="ALWAYS" spacing="1">
              <Label text="Петренко Олег" styleClass="td-normal"/>
              <Label text="Париж · 1 лип." styleClass="td-muted"/>
            </VBox>
            <Label text="Очікує оплати" styleClass="pill-pending"/>
          </HBox>
          <!-- Row 3 -->
          <HBox styleClass="table-row" spacing="10">
            <Label text="КТ" styleClass="c-ava ca-c"/>
            <VBox HBox.hgrow="ALWAYS" spacing="1">
              <Label text="Коваль Тетяна" styleClass="td-normal"/>
              <Label text="Японія · 5 серп." styleClass="td-muted"/>
            </VBox>
            <Label text="Підтверджено" styleClass="pill-confirmed"/>
          </HBox>
          <!-- Row 4 -->
          <HBox styleClass="table-row" spacing="10">
            <Label text="ША" styleClass="c-ava ca-d"/>
            <VBox HBox.hgrow="ALWAYS" spacing="1">
              <Label text="Шевченко Андрій" styleClass="td-normal"/>
              <Label text="Цюріх · 12 серп." styleClass="td-muted"/>
            </VBox>
            <Label text="Сплачено" styleClass="pill-paid"/>
          </HBox>
          <!-- Row 5 -->
          <HBox styleClass="table-row" spacing="10">
            <Label text="БЛ" styleClass="c-ava ca-a"/>
            <VBox HBox.hgrow="ALWAYS" spacing="1">
              <Label text="Бондаренко Ліна" styleClass="td-normal"/>
              <Label text="Марокко · 3 вер." styleClass="td-muted"/>
            </VBox>
            <Label text="Скасовано" styleClass="pill-cancelled"/>
          </HBox>
        </VBox>
      </VBox>
    </HBox>

  </VBox>
</ScrollPane>
