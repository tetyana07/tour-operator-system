<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>
<StackPane styleClass="modal-overlay-pane"
  xmlns:fx="http://javafx.com/fxml"
  fx:controller="com.touroperator.ui.NewBookingController">

  <VBox styleClass="tour-detail-modal" maxWidth="580" maxHeight="820"
    style="-fx-background-color:#f8faf6; -fx-background-radius:24; -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.28),40,0,0,8);">

    <!-- HEADER — зелений градієнт -->
    <HBox style="-fx-background-color:linear-gradient(to bottom right, #1a3d08, #2d6b1a);
                 -fx-background-radius:24 24 0 0; -fx-padding:20 24 16 28;"
      alignment="CENTER_LEFT">
      <VBox HBox.hgrow="ALWAYS" spacing="4">
        <Label text="✈  БРОНЮВАННЯ ТУРУ"
          style="-fx-font-size:10px; -fx-font-weight:bold; -fx-text-fill:#8fcba3;
                 -fx-letter-spacing:2;"/>
        <Label text="Заповніть деталі поїздки"
          style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:white;"/>
        <Label fx:id="tourBadge" text=""
          style="-fx-background-color:rgba(255,255,255,0.15); -fx-background-radius:20;
                 -fx-padding:3 10; -fx-text-fill:white; -fx-font-size:11px;
                 -fx-margin-top:4;"/>
      </VBox>
      <Label text="✕" styleClass="tour-modal-close-btn" onMouseClicked="#onClose"/>
    </HBox>

    <!-- BODY -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="content-scroll"
      style="-fx-background:transparent; -fx-background-color:transparent;">
      <VBox spacing="0" style="-fx-padding:0; -fx-background-color:#f8faf6;">

        <!-- Секція: ТУР (прихована для клієнта якщо тур вже обрано) -->
        <VBox fx:id="tourSection" style="-fx-padding:20 28 0 28;" spacing="6">
          <Label text="ТУР" style="-fx-font-size:10px; -fx-font-weight:bold;
                 -fx-text-fill:#5a8a3a; -fx-letter-spacing:1.5;"/>
          <ComboBox fx:id="tourCombo" styleClass="form-combo" maxWidth="Infinity"
            onAction="#onTourChanged"
            style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                   -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
        </VBox>

        <!-- Секція вибору клієнта — видима тільки для адміна -->
        <VBox fx:id="clientSection" visible="false" managed="false" style="-fx-padding:0 28;" spacing="6">
          <Label text="КЛІЄНТ" style="-fx-font-size:10px; -fx-font-weight:bold;
                 -fx-text-fill:#5a8a3a; -fx-letter-spacing:1.5;"/>
          <ComboBox fx:id="clientCombo" maxWidth="Infinity"
            style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                   -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
          <Region prefHeight="10"/>
          <Line style="-fx-stroke:#e8f0e0; -fx-stroke-width:1;"
            startX="0" endX="524" translateY="0"/>
        </VBox>

        <!-- Divider -->
        <Region prefHeight="16"/>
        <Line style="-fx-stroke:#e8f0e0; -fx-stroke-width:1;"
          startX="28" endX="552" translateY="0"/>
        <Region prefHeight="16"/>

        <!-- Секція: ТУРИСТИ -->
        <VBox style="-fx-padding:0 28;" spacing="10">
          <Label text="ТУРИСТИ" style="-fx-font-size:10px; -fx-font-weight:bold;
                 -fx-text-fill:#5a8a3a; -fx-letter-spacing:1.5;"/>
          <GridPane hgap="14">
            <columnConstraints>
              <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
              <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
            <VBox spacing="5" GridPane.columnIndex="0">
              <Label text="Дорослих"
                style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
              <Spinner fx:id="paxSpinner" maxWidth="Infinity"
                style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                       -fx-border-radius:10; -fx-background-radius:10;"/>
            </VBox>
            <VBox spacing="5" GridPane.columnIndex="1">
              <Label text="Дітей (знижка 50%)"
                style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
              <Spinner fx:id="childSpinner" maxWidth="Infinity"
                style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                       -fx-border-radius:10; -fx-background-radius:10;"/>
            </VBox>
          </GridPane>
        </VBox>

        <Region prefHeight="16"/>
        <Line style="-fx-stroke:#e8f0e0; -fx-stroke-width:1;"
          startX="28" endX="552" translateY="0"/>
        <Region prefHeight="16"/>

        <!-- Секція: ПРОЖИВАННЯ та ЕКСКУРСІЯ -->
        <VBox style="-fx-padding:0 28;" spacing="10">
          <Label text="ДОДАТКОВО" style="-fx-font-size:10px; -fx-font-weight:bold;
                 -fx-text-fill:#5a8a3a; -fx-letter-spacing:1.5;"/>
          <VBox spacing="5">
            <Label text="Готель"
              style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
            <ComboBox fx:id="hotelCombo" maxWidth="Infinity"
              style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                     -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
          </VBox>
          <VBox spacing="5">
            <Label text="Екскурсія (опціонально)"
              style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
            <ComboBox fx:id="excursionCombo" maxWidth="Infinity"
              onAction="#onExcursionChanged"
              style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                     -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
          </VBox>
          <GridPane hgap="14">
            <columnConstraints>
              <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
              <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
            <VBox spacing="5" GridPane.columnIndex="0">
              <Label text="Трансфер"
                style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
              <ComboBox fx:id="transferCombo" maxWidth="Infinity"
                style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                       -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
            </VBox>
            <VBox spacing="5" GridPane.columnIndex="1">
              <Label text="Страховка"
                style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
              <ComboBox fx:id="insuranceCombo" maxWidth="Infinity"
                style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                       -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
            </VBox>
          </GridPane>
        </VBox>

        <Region prefHeight="16"/>
        <Line style="-fx-stroke:#e8f0e0; -fx-stroke-width:1;"
          startX="28" endX="552" translateY="0"/>
        <Region prefHeight="16"/>

        <!-- Секція: ЗНИЖКА -->
        <VBox style="-fx-padding:0 28;" spacing="10">
          <Label text="ЗНИЖКА" style="-fx-font-size:10px; -fx-font-weight:bold;
                 -fx-text-fill:#5a8a3a; -fx-letter-spacing:1.5;"/>
          <GridPane hgap="14">
            <columnConstraints>
              <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
              <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
            </columnConstraints>
            <VBox spacing="5" GridPane.columnIndex="0">
              <Label text="Промокод"
                style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
              <TextField fx:id="promoField" promptText="Наприклад: SUMMER25"
                onAction="#onPromoApply"
                style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                       -fx-border-radius:10; -fx-background-radius:10;
                       -fx-padding:8 12; -fx-font-size:13px;"/>
            </VBox>
            <VBox spacing="5" GridPane.columnIndex="1">
              <Label text="Тип знижки"
                style="-fx-font-size:12px; -fx-text-fill:#6a7a5a;"/>
              <ComboBox fx:id="discountCombo" maxWidth="Infinity"
                onAction="#onDiscountChanged"
                style="-fx-background-color:white; -fx-border-color:#d4e8c2;
                       -fx-border-radius:10; -fx-background-radius:10; -fx-font-size:13px;"/>
            </VBox>
          </GridPane>
        </VBox>

        <Region prefHeight="20"/>

        <!-- ПІДСУМОК — зелена картка -->
        <VBox style="-fx-margin:0 28; -fx-padding:20 28;" spacing="0">
          <VBox style="-fx-background-color:linear-gradient(to bottom right,#1a3d08,#2d6b1a);
                       -fx-background-radius:16; -fx-padding:20;" spacing="10">
            <Label text="ПІДСУМОК ВАРТОСТІ"
              style="-fx-font-size:10px; -fx-font-weight:bold;
                     -fx-text-fill:#8fcba3; -fx-letter-spacing:1.5;"/>

            <!-- Базова ціна -->
            <HBox alignment="CENTER_LEFT">
              <Label fx:id="baseLine" text="Базова вартість"
                style="-fx-font-size:13px; -fx-text-fill:rgba(255,255,255,0.7);"
                HBox.hgrow="ALWAYS"/>
              <Label fx:id="basePrice" text="0 грн"
                style="-fx-font-size:13px; -fx-text-fill:rgba(255,255,255,0.7);"/>
            </HBox>

            <!-- Знижка -->
            <HBox alignment="CENTER_LEFT">
              <Label text="Знижка"
                style="-fx-font-size:13px; -fx-text-fill:#8fcba3;"
                HBox.hgrow="ALWAYS"/>
              <Label fx:id="discountLine" text="− 0 грн"
                style="-fx-font-size:13px; -fx-text-fill:#8fcba3;"/>
            </HBox>

            <!-- Роздільник -->
            <Region prefHeight="1"
              style="-fx-background-color:rgba(255,255,255,0.15);"/>

            <!-- Підсумок -->
            <HBox alignment="CENTER_LEFT">
              <Label text="До сплати"
                style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:white;"
                HBox.hgrow="ALWAYS"/>
              <Label fx:id="totalPrice" text="0 грн"
                style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#c8e6a0;"/>
            </HBox>
          </VBox>
        </VBox>

        <Region prefHeight="20"/>
      </VBox>
    </ScrollPane>

    <!-- FOOTER -->
    <HBox alignment="CENTER_RIGHT" spacing="12"
      style="-fx-padding:16 28; -fx-background-color:#f0f5ec;
             -fx-background-radius:0 0 24 24;
             -fx-border-color:#e0ead6; -fx-border-width:1 0 0 0;">
      <Button text="Скасувати" onAction="#onClose"
        style="-fx-background-color:transparent; -fx-border-color:#b0c8a0;
               -fx-border-radius:10; -fx-background-radius:10;
               -fx-text-fill:#4a7a2a; -fx-font-size:13px; -fx-padding:10 20;
               -fx-cursor:hand;"/>
      <Button text="✈  Забронювати" onAction="#onSaveBooking"
        style="-fx-background-color:linear-gradient(to right,#2d6b1a,#4a9a2a);
               -fx-background-radius:10; -fx-text-fill:white;
               -fx-font-size:13px; -fx-font-weight:bold; -fx-padding:10 24;
               -fx-cursor:hand; -fx-effect:dropshadow(gaussian,rgba(45,107,26,0.4),8,0,0,3);"/>
    </HBox>

  </VBox>
</StackPane>
